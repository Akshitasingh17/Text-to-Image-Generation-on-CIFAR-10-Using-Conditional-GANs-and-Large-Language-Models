import torch
import torch.nn as nn
import torchvision
import torchvision.transforms as transforms
from torch.utils.data import DataLoader, Dataset
from torchvision.utils import make_grid
from transformers import pipeline
import matplotlib.pyplot as plt
import numpy as np
from tqdm import tqdm
transform = transforms.Compose([
    transforms.ToTensor(),
    transforms.Normalize((0.5,), (0.5,))
])

trainset = torchvision.datasets.CIFAR10(root='./data', train=True, download=True, transform=transform)
trainloader = DataLoader(trainset, batch_size=128, shuffle=True)

classes = trainset.classes
generator = pipeline('text-generation', model='gpt2')

def generate_prompts(classes):
    prompts = {}
    for cls in classes:
        prompt = f"Describe a {cls} in a realistic scene."
        text = generator(prompt, max_length=20, num_return_sequences=1)[0]['generated_text']
        prompts[cls] = text.strip()
    return prompts

class_prompts = generate_prompts(classes)
print(class_prompts)
class Generator(nn.Module):
    def __init__(self, noise_dim, embed_dim, img_channels=3, feature_g=64):
        super(Generator, self).__init__()
        self.label_emb = nn.Embedding(10, embed_dim)
        self.net = nn.Sequential(
            nn.Linear(noise_dim + embed_dim, 256),
            nn.ReLU(),
            nn.Linear(256, 512),
            nn.ReLU(),
            nn.Linear(512, 1024),
            nn.ReLU(),
            nn.Linear(1024, 3 * 32 * 32),
            nn.Tanh()
        )

    def forward(self, noise, labels):
        label_embedding = self.label_emb(labels)
        x = torch.cat((noise, label_embedding), dim=1)
        out = self.net(x)
        return out.view(-1, 3, 32, 32)
class Discriminator(nn.Module):
    def __init__(self, embed_dim, img_channels=3, feature_d=64):
        super(Discriminator, self).__init__()
        self.label_emb = nn.Embedding(10, embed_dim)
        self.net = nn.Sequential(
            nn.Linear(3*32*32 + embed_dim, 512),
            nn.LeakyReLU(0.2),
            nn.Linear(512, 256),
            nn.LeakyReLU(0.2),
            nn.Linear(256, 1),
            nn.Sigmoid()
        )

    def forward(self, img, labels):
        label_embedding = self.label_emb(labels)
        x = torch.cat((img.view(img.size(0), -1), label_embedding), dim=1)
        return self.net(x)
device = torch.device("cuda" if torch.cuda.is_available() else "cpu")
noise_dim = 100
embed_dim = 100

G = Generator(noise_dim, embed_dim).to(device)
D = Discriminator(embed_dim).to(device)

criterion = nn.BCELoss()
optimizer_G = torch.optim.Adam(G.parameters(), lr=0.0002)
optimizer_D = torch.optim.Adam(D.parameters(), lr=0.0002)

epochs = 50

for epoch in range(epochs):
    for imgs, labels in tqdm(trainloader):
        imgs, labels = imgs.to(device), labels.to(device)
        batch_size = imgs.size(0)

        real = torch.ones(batch_size, 1).to(device)
        fake = torch.zeros(batch_size, 1).to(device)

        optimizer_D.zero_grad()
        outputs = D(imgs, labels)
        d_loss_real = criterion(outputs, real)

        noise = torch.randn(batch_size, noise_dim).to(device)
        fake_imgs = G(noise, labels)
        outputs = D(fake_imgs.detach(), labels)
        d_loss_fake = criterion(outputs, fake)

        d_loss = d_loss_real + d_loss_fake
        d_loss.backward()
        optimizer_D.step()

        optimizer_G.zero_grad()
        noise = torch.randn(batch_size, noise_dim).to(device)
        fake_imgs = G(noise, labels)
        outputs = D(fake_imgs, labels)
        g_loss = criterion(outputs, real)
        g_loss.backward()
        optimizer_G.step()

    print(f"Epoch {epoch+1}/{epochs} | D Loss: {d_loss.item()} | G Loss: {g_loss.item()}")
def show_generated_images():
    G.eval()
    with torch.no_grad():
        z = torch.randn(10, noise_dim).to(device)
        labels = torch.arange(0, 10).to(device)
        gen_imgs = G(z, labels)
        grid = make_grid(gen_imgs, nrow=5, normalize=True)
        plt.figure(figsize=(10, 5))
        plt.imshow(np.transpose(grid.cpu().numpy(), (1, 2, 0)))
        plt.axis('off')
        plt.title("Generated Images from Prompts")
        plt.show()

show_generated_images()
